             older versions: ControllerAdviceBean(Object) was removed)   -->
        <springdoc.version>2.8.15</springdoc.version>
        <!-- jjwt split into api+impl+jackson since 0.10.0              -->
        <jjwt.version>0.12.6</jjwt.version>
        <feign.version>13.5</feign.version>
        <networknt-validator.version>1.5.8</networknt-validator.version>

        <!-- ── Messaging ─────────────────────────────────────────────── -->
        <!-- Camel 4.10.x LTS — compatible with Boot 3.x               -->
        <camel.version>4.10.4</camel.version>
        <!-- spring-kafka and kafka-clients are Boot-managed             -->

        <!-- ── Storage ───────────────────────────────────────────────── -->
        <minio.version>8.5.17</minio.version>
        <aws-sdk.version>2.31.78</aws-sdk.version>
        <lakefs.version>1.52.0</lakefs.version>

        <!-- ── Security ──────────────────────────────────────────────── -->
        <jasypt-spring-boot.version>3.0.5</jasypt-spring-boot.version>

        <!-- ── Utilities ─────────────────────────────────────────────── -->
        <joda-time.version>2.13.1</joda-time.version>
        <commons-lang3.version>3.17.0</commons-lang3.version>
        <commons-text.version>1.13.1</commons-text.version>
        <commons-io.version>2.18.0</commons-io.version>
        <pdfbox.version>3.0.3</pdfbox.version>

        <!-- ── Build plugins ─────────────────────────────────────────── -->
        <maven-compiler-plugin.version>3.13.0</maven-compiler-plugin.version>
        <maven-surefire-plugin.version>3.5.3</maven-surefire-plugin.version>
        <maven-failsafe-plugin.version>3.5.3</maven-failsafe-plugin.version>
        <maven-deploy-plugin.version>3.1.4</maven-deploy-plugin.version>
        <maven-source-plugin.version>3.3.1</maven-source-plugin.version>
    </properties>

