    <!-- ================================================================
         CENTRALIZED BUILD CONFIGURATION
         All sub-modules inherit compiler settings and surefire config.

         TEST STRATEGY — NON-PARALLEL (sequential):
           - Testcontainers port conflicts are avoided
           - Spring ApplicationContext caching works optimally
           - CI builds are reproducible and deterministic
           - Debugging is straightforward (no interleaved output)
         ================================================================ -->
    <build>
        <pluginManagement>
            <plugins>

                <!-- Compiler — annotation processor order matters:
                     1. lombok        → generates getters/setters/builders
                     2. binding shim  → ensures ordering is enforced
                     3. mapstruct     → reads Lombok-generated code
                     Reverse order causes MapStruct to miss fields.    -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>${maven-compiler-plugin.version}</version>
                    <configuration>
                        <encoding>${maven.compiler.encoding}</encoding>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <parameters>true</parameters>
                        <annotationProcessorPaths>
                            <path>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok</artifactId>
                                <version>${lombok.version}</version>
                            </path>
                            <path>
                                <groupId>org.projectlombok</groupId>
                                <artifactId>lombok-mapstruct-binding</artifactId>
                                <version>${lombok-mapstruct-binding.version}</version>
                            </path>
                            <path>
                                <groupId>org.mapstruct</groupId>
                                <artifactId>mapstruct-processor</artifactId>
                                <version>${mapstruct.version}</version>
                            </path>
                        </annotationProcessorPaths>
                    </configuration>
                </plugin>

                <!-- Surefire (unit tests) — SEQUENTIAL execution
                     parallel=none  → no thread-level parallelism
                     forkCount=1    → single forked JVM
                     reuseForks=true → reuse JVM across test classes
                     runOrder=alphabetical → reproducible ordering     -->
                <plugin>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${maven-surefire-plugin.version}</version>
                    <configuration>
                        <parallel>none</parallel>
                        <forkCount>1</forkCount>
                        <reuseForks>true</reuseForks>
                        <threadCount>1</threadCount>
                        <perCoreThreadCount>false</perCoreThreadCount>
                        <runOrder>alphabetical</runOrder>
                        <failIfNoTests>false</failIfNoTests>
                        <useModulePath>false</useModulePath>
                    </configuration>
                </plugin>

                <!-- Failsafe (integration tests) — also SEQUENTIAL    -->
                <plugin>
                    <artifactId>maven-failsafe-plugin</artifactId>
                    <version>${maven-failsafe-plugin.version}</version>
                    <configuration>
                        <parallel>none</parallel>
                        <forkCount>1</forkCount>
                        <reuseForks>true</reuseForks>
                        <threadCount>1</threadCount>
                        <perCoreThreadCount>false</perCoreThreadCount>
                        <runOrder>alphabetical</runOrder>
                        <failIfNoTests>false</failIfNoTests>
                    </configuration>
                </plugin>

                <plugin>
                    <artifactId>maven-deploy-plugin</artifactId>
                    <version>${maven-deploy-plugin.version}</version>
                </plugin>

                <plugin>
                    <artifactId>maven-source-plugin</artifactId>
                    <version>${maven-source-plugin.version}</version>
                    <executions>
                        <execution>
                            <id>attach-sources</id>
                            <goals>
                                <goal>jar-no-fork</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>

            </plugins>
        </pluginManagement>

        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>
            <plugin>
                <artifactId>maven-deploy-plugin</artifactId>
                <executions>
                    <execution>
                        <id>default-deploy</id>
                        <phase>deploy</phase>
                        <goals>
                            <goal>deploy</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

