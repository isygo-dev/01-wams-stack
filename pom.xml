    <!-- ================================================================
         CENTRALIZED VERSION PROPERTIES — single source of truth.
         Target: Spring Boot 3.5.13 (released 2026-03-26).
         Spring Cloud 2025.0.2 is the release train for Boot 3.5.13.

         BOOT-MANAGED versions (do NOT pin in sub-modules):
           Spring Framework 6.2.x, Spring Security 6.5.x,
           Spring Data 2025.0.x, Hibernate 6.6.45.Final,
           Jackson 2.21.2 (2.19/2.20 reached EOL → Boot upgraded),
           HikariCP, Flyway 11.x, Quartz 2.5.x, PostgreSQL 42.7.10,
           Testcontainers 1.21.x, JUnit Jupiter 5.12.x, Mockito 5.17.x.
         ================================================================ -->
    <properties>
        <java.version>17</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.encoding>UTF-8</maven.compiler.encoding>

        <!-- ── Spring ──────────────────────────────────────────────── -->
        <spring-boot.version>3.5.13</spring-boot.version>
        <spring-cloud.version>2025.0.2</spring-cloud.version>

        <!-- ── Code generation ─────────────────────────────────────── -->
        <!-- Lombok MUST be in <dependencies> (compile scope) so that
             'import lombok.Setter' / 'import lombok.Data' resolves.
             It also goes in annotationProcessorPaths to drive APT.      -->
        <lombok.version>1.18.38</lombok.version>
        <mapstruct.version>1.6.3</mapstruct.version>
        <!-- Binding shim: guarantees Lombok runs before MapStruct       -->
        <lombok-mapstruct-binding.version>0.2.0</lombok-mapstruct-binding.version>

        <!-- ── Persistence (Boot-managed — listed for visibility) ───── -->
        <hibernate.version>6.6.45.Final</hibernate.version>
        <postgresql.version>42.7.10</postgresql.version>
        <h2.version>2.3.232</h2.version>
        <flyway.version>11.9.1</flyway.version>

        <!-- ── Web / API ────────────────────────────────────────────── -->
